# ── Supabase (Noah AI production project) ──────────────────────────────
# The dashboard reads aggregate metrics with the public anon/publishable
# key only. RLS on the production DB authorises what this key can read.
# We NEVER write to production from the dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://bhdzwfznafquyhpqenpm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Dashboard access control ───────────────────────────────────────────
# Who may view /dashboard. Two independent allow rules (case-insensitive):
#
#   DASHBOARD_ADMIN_DOMAINS — comma-separated email domains; ANY Google
#     account on one of these domains is allowed. Defaults to "pixpel.io"
#     when unset, so every @pixpel.io account can sign in out of the box.
#   DASHBOARD_ADMIN_EMAILS  — comma-separated individual emails, to grant
#     access to people outside the allowed domains.
#
# Anyone matching neither rule is signed straight back out.
DASHBOARD_ADMIN_DOMAINS=pixpel.io
DASHBOARD_ADMIN_EMAILS=

# ── Site URL (used to build the OAuth redirect target) ─────────────────
# In production set this to the deployed origin, e.g. https://noah-ai.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
